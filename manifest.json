{
  "manifest_version": 3,
  "name": "Teams Video Pro Downloader",
  "version": "2.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://*.sharepoint.com/*", "*://*.microsoftonline.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sharepoint.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}